model:
  name: {{ model_name }}
  description: "Retail analytics model — auto-generated by ts-demo-factory"
  model_tables:
    - name: SALES_FACT
      fqn: {{ table_guids['SALES_FACT'] }}
    - name: DIM_STORE
      fqn: {{ table_guids['DIM_STORE'] }}
      joins:
        - "with": SALES_FACT
          "on": "[SALES_FACT::STORE_ID] = [DIM_STORE::STORE_ID]"
          type: LEFT_OUTER
          cardinality: MANY_TO_ONE
    - name: DIM_PRODUCT
      fqn: {{ table_guids['DIM_PRODUCT'] }}
      joins:
        - "with": SALES_FACT
          "on": "[SALES_FACT::PRODUCT_ID] = [DIM_PRODUCT::PRODUCT_ID]"
          type: LEFT_OUTER
          cardinality: MANY_TO_ONE
    - name: DIM_CUSTOMER
      fqn: {{ table_guids['DIM_CUSTOMER'] }}
      joins:
        - "with": SALES_FACT
          "on": "[SALES_FACT::CUSTOMER_ID] = [DIM_CUSTOMER::CUSTOMER_ID]"
          type: LEFT_OUTER
          cardinality: MANY_TO_ONE
  columns:
    - name: Sale ID
      column_id: SALES_FACT::SALE_ID
      properties:
        column_type: ATTRIBUTE
    - name: Date
      column_id: SALES_FACT::DATE
      properties:
        column_type: ATTRIBUTE
        index_type: DONT_INDEX
    - name: Revenue
      column_id: SALES_FACT::REVENUE
      properties:
        column_type: MEASURE
        aggregation: SUM
    - name: Cost
      column_id: SALES_FACT::COST
      properties:
        column_type: MEASURE
        aggregation: SUM
    - name: Discount
      column_id: SALES_FACT::DISCOUNT
      properties:
        column_type: MEASURE
        aggregation: AVERAGE
    - name: Quantity
      column_id: SALES_FACT::QUANTITY
      properties:
        column_type: MEASURE
        aggregation: SUM
    - name: Store Name
      column_id: DIM_STORE::STORE_NAME
      properties:
        column_type: ATTRIBUTE
    - name: Region
      column_id: DIM_STORE::REGION
      properties:
        column_type: ATTRIBUTE
    - name: City (Store)
      column_id: DIM_STORE::CITY
      properties:
        column_type: ATTRIBUTE
    - name: Country
      column_id: DIM_STORE::COUNTRY
      properties:
        column_type: ATTRIBUTE
    - name: Store Size (sqft)
      column_id: DIM_STORE::STORE_SIZE_SQFT
      properties:
        column_type: MEASURE
        aggregation: SUM
    - name: Product Name
      column_id: DIM_PRODUCT::PRODUCT_NAME
      properties:
        column_type: ATTRIBUTE
    - name: Category
      column_id: DIM_PRODUCT::CATEGORY
      properties:
        column_type: ATTRIBUTE
    - name: Subcategory
      column_id: DIM_PRODUCT::SUBCATEGORY
      properties:
        column_type: ATTRIBUTE
    - name: Brand
      column_id: DIM_PRODUCT::BRAND
      properties:
        column_type: ATTRIBUTE
    - name: Unit Price
      column_id: DIM_PRODUCT::UNIT_PRICE
      properties:
        column_type: MEASURE
        aggregation: AVERAGE
    - name: Customer Name
      column_id: DIM_CUSTOMER::CUSTOMER_NAME
      properties:
        column_type: ATTRIBUTE
    - name: Loyalty Tier
      column_id: DIM_CUSTOMER::LOYALTY_TIER
      properties:
        column_type: ATTRIBUTE
    - name: Age Group
      column_id: DIM_CUSTOMER::AGE_GROUP
      properties:
        column_type: ATTRIBUTE
    - name: Gender
      column_id: DIM_CUSTOMER::GENDER
      properties:
        column_type: ATTRIBUTE
    - name: City (Customer)
      column_id: DIM_CUSTOMER::CITY
      properties:
        column_type: ATTRIBUTE
