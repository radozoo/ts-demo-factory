liveboard:
  name: {{ liveboard_name }}
  description: "Retail analytics liveboard — auto-generated by ts-demo-factory"
  visualizations:
    - id: viz_revenue_by_region
      answer:
        name: Revenue by Region
        description: Total revenue broken down by store region
        tables:
          - id: {{ worksheet_guid }}
            name: {{ worksheet_name }}
        search_query: "[Revenue] [Region]"
        answer_columns:
          - name: Region
          - name: Revenue
        chart:
          type: BAR
          chart_columns:
            - column_id: Region
              series_columns: []
            - column_id: Revenue
              series_columns: []
    - id: viz_revenue_trend
      answer:
        name: Revenue Trend
        description: Monthly revenue over time
        tables:
          - id: {{ worksheet_guid }}
            name: {{ worksheet_name }}
        search_query: "[Revenue] [Date].monthly"
        answer_columns:
          - name: Date
          - name: Revenue
        chart:
          type: LINE
          chart_columns:
            - column_id: Date
              series_columns: []
            - column_id: Revenue
              series_columns: []
    - id: viz_top_categories
      answer:
        name: Top Categories by Revenue
        description: Revenue breakdown by product category
        tables:
          - id: {{ worksheet_guid }}
            name: {{ worksheet_name }}
        search_query: "[Revenue] [Category] top 8"
        answer_columns:
          - name: Category
          - name: Revenue
        chart:
          type: PIE
          chart_columns:
            - column_id: Category
              series_columns: []
            - column_id: Revenue
              series_columns: []
    - id: viz_loyalty_revenue
      answer:
        name: Revenue by Loyalty Tier
        description: Revenue contribution per customer loyalty tier
        tables:
          - id: {{ worksheet_guid }}
            name: {{ worksheet_name }}
        search_query: "[Revenue] [Loyalty Tier]"
        answer_columns:
          - name: Loyalty Tier
          - name: Revenue
        chart:
          type: BAR
          chart_columns:
            - column_id: Loyalty Tier
              series_columns: []
            - column_id: Revenue
              series_columns: []
    - id: viz_quantity_by_brand
      answer:
        name: Top Brands by Quantity Sold
        description: Units sold per brand, top 10
        tables:
          - id: {{ worksheet_guid }}
            name: {{ worksheet_name }}
        search_query: "[Quantity] [Brand] top 10"
        answer_columns:
          - name: Brand
          - name: Quantity
        chart:
          type: COLUMN
          chart_columns:
            - column_id: Brand
              series_columns: []
            - column_id: Quantity
              series_columns: []
    - id: viz_avg_discount_by_category
      answer:
        name: Avg Discount by Category
        description: Average discount percentage per product category
        tables:
          - id: {{ worksheet_guid }}
            name: {{ worksheet_name }}
        search_query: "average [Discount] [Category]"
        answer_columns:
          - name: Category
          - name: Discount
        chart:
          type: BAR
          chart_columns:
            - column_id: Category
              series_columns: []
            - column_id: Discount
              series_columns: []
  layout:
    tiles:
      - visualization_id: viz_revenue_by_region
        x: 0
        y: 0
        height: 4
        width: 6
      - visualization_id: viz_revenue_trend
        x: 6
        y: 0
        height: 4
        width: 6
      - visualization_id: viz_top_categories
        x: 0
        y: 4
        height: 4
        width: 4
      - visualization_id: viz_loyalty_revenue
        x: 4
        y: 4
        height: 4
        width: 4
      - visualization_id: viz_quantity_by_brand
        x: 8
        y: 4
        height: 4
        width: 4
      - visualization_id: viz_avg_discount_by_category
        x: 0
        y: 8
        height: 4
        width: 6
