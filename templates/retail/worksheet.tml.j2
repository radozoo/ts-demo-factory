worksheet:
  name: {{ worksheet_name }}
  description: "Retail analytics worksheet — auto-generated by ts-demo-factory"
  tables:
    - name: SALES_FACT
      id: SALES_FACT
      fqn: {{ table_guids['SALES_FACT'] }}
    - name: DIM_STORE
      id: DIM_STORE
      fqn: {{ table_guids['DIM_STORE'] }}
    - name: DIM_PRODUCT
      id: DIM_PRODUCT
      fqn: {{ table_guids['DIM_PRODUCT'] }}
    - name: DIM_CUSTOMER
      id: DIM_CUSTOMER
      fqn: {{ table_guids['DIM_CUSTOMER'] }}
  table_paths:
    - id: SALES_FACT_1
      table: SALES_FACT
      join_path:
        - {}
    - id: DIM_STORE_1
      table: DIM_STORE
      join_path:
        - join:
            - SALES_FACT_to_DIM_STORE
    - id: DIM_PRODUCT_1
      table: DIM_PRODUCT
      join_path:
        - join:
            - SALES_FACT_to_DIM_PRODUCT
    - id: DIM_CUSTOMER_1
      table: DIM_CUSTOMER
      join_path:
        - join:
            - SALES_FACT_to_DIM_CUSTOMER
  joins:
    - name: SALES_FACT_to_DIM_STORE
      source: SALES_FACT_1
      destination: DIM_STORE_1
      type: LEFT_OUTER
      is_one_to_one: false
      "on":
        - "[SALES_FACT_1::STORE_ID] = [DIM_STORE_1::STORE_ID]"
    - name: SALES_FACT_to_DIM_PRODUCT
      source: SALES_FACT_1
      destination: DIM_PRODUCT_1
      type: LEFT_OUTER
      is_one_to_one: false
      "on":
        - "[SALES_FACT_1::PRODUCT_ID] = [DIM_PRODUCT_1::PRODUCT_ID]"
    - name: SALES_FACT_to_DIM_CUSTOMER
      source: SALES_FACT_1
      destination: DIM_CUSTOMER_1
      type: LEFT_OUTER
      is_one_to_one: false
      "on":
        - "[SALES_FACT_1::CUSTOMER_ID] = [DIM_CUSTOMER_1::CUSTOMER_ID]"
  worksheet_columns:
    - name: Sale ID
      column_id: SALES_FACT_1::SALE_ID
      properties:
        column_type: ATTRIBUTE
    - name: Date
      column_id: SALES_FACT_1::DATE
      properties:
        column_type: ATTRIBUTE
        index_type: DONT_INDEX
    - name: Revenue
      column_id: SALES_FACT_1::REVENUE
      properties:
        column_type: MEASURE
        aggregation: SUM
    - name: Cost
      column_id: SALES_FACT_1::COST
      properties:
        column_type: MEASURE
        aggregation: SUM
    - name: Discount
      column_id: SALES_FACT_1::DISCOUNT
      properties:
        column_type: MEASURE
        aggregation: AVERAGE
    - name: Quantity
      column_id: SALES_FACT_1::QUANTITY
      properties:
        column_type: MEASURE
        aggregation: SUM
    - name: Store Name
      column_id: DIM_STORE_1::STORE_NAME
      properties:
        column_type: ATTRIBUTE
    - name: Region
      column_id: DIM_STORE_1::REGION
      properties:
        column_type: ATTRIBUTE
    - name: City (Store)
      column_id: DIM_STORE_1::CITY
      properties:
        column_type: ATTRIBUTE
    - name: Country
      column_id: DIM_STORE_1::COUNTRY
      properties:
        column_type: ATTRIBUTE
    - name: Store Size (sqft)
      column_id: DIM_STORE_1::STORE_SIZE_SQFT
      properties:
        column_type: MEASURE
        aggregation: SUM
    - name: Product Name
      column_id: DIM_PRODUCT_1::PRODUCT_NAME
      properties:
        column_type: ATTRIBUTE
    - name: Category
      column_id: DIM_PRODUCT_1::CATEGORY
      properties:
        column_type: ATTRIBUTE
    - name: Subcategory
      column_id: DIM_PRODUCT_1::SUBCATEGORY
      properties:
        column_type: ATTRIBUTE
    - name: Brand
      column_id: DIM_PRODUCT_1::BRAND
      properties:
        column_type: ATTRIBUTE
    - name: Unit Price
      column_id: DIM_PRODUCT_1::UNIT_PRICE
      properties:
        column_type: MEASURE
        aggregation: AVERAGE
    - name: Customer Name
      column_id: DIM_CUSTOMER_1::CUSTOMER_NAME
      properties:
        column_type: ATTRIBUTE
    - name: Loyalty Tier
      column_id: DIM_CUSTOMER_1::LOYALTY_TIER
      properties:
        column_type: ATTRIBUTE
    - name: Age Group
      column_id: DIM_CUSTOMER_1::AGE_GROUP
      properties:
        column_type: ATTRIBUTE
    - name: Gender
      column_id: DIM_CUSTOMER_1::GENDER
      properties:
        column_type: ATTRIBUTE
    - name: City (Customer)
      column_id: DIM_CUSTOMER_1::CITY
      properties:
        column_type: ATTRIBUTE
