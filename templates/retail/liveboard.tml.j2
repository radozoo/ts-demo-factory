liveboard:
  name: {{ liveboard_name }}
  description: "Retail analytics liveboard — auto-generated by ts-demo-factory"
  visualizations:
    - id: viz_revenue_by_region
      answer:
        name: Revenue by Region
        tables:
          - id: {{ model_name }}
            name: {{ model_name }}
            fqn: {{ model_guid }}
        search_query: "[Revenue] [Region]"
        answer_columns:
          - name: Region
          - name: Total Revenue
        table:
          table_columns:
            - column_id: Region
              headline_aggregation: COUNT_DISTINCT
            - column_id: Total Revenue
              headline_aggregation: SUM
          ordered_column_ids:
            - Region
            - Total Revenue
          client_state: ""
        chart:
          type: BAR
          chart_columns:
            - column_id: Region
            - column_id: Total Revenue
          axis_configs:
            - x:
                - Region
              y:
                - Total Revenue
          client_state: ""
        display_mode: CHART_MODE
    - id: viz_revenue_trend
      answer:
        name: Revenue Trend
        tables:
          - id: {{ model_name }}
            name: {{ model_name }}
            fqn: {{ model_guid }}
        search_query: "[Revenue] [Date].monthly"
        answer_columns:
          - name: "Month(Date)"
          - name: Total Revenue
        table:
          table_columns:
            - column_id: "Month(Date)"
              headline_aggregation: MIN-MAX
            - column_id: Total Revenue
              headline_aggregation: SUM
          ordered_column_ids:
            - "Month(Date)"
            - Total Revenue
          client_state: ""
        chart:
          type: LINE
          chart_columns:
            - column_id: "Month(Date)"
            - column_id: Total Revenue
          axis_configs:
            - x:
                - "Month(Date)"
              y:
                - Total Revenue
          client_state: ""
        display_mode: CHART_MODE
